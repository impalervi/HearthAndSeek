<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/
        https://raw.githubusercontent.com/AakashSasikumar/WoW-UIDev/main/UI/UI.xsd">

    <!--
        HearthAndSeek: CatalogTemplates.xml
        Minimalist button template — all styling done in Lua (OnLoad).
    -->

    <Button name="HearthAndSeekCatalogItemTemplate" virtual="true">
        <Size x="56" y="56"/>
        <Scripts>
            <OnLoad>
                HearthAndSeek_CatalogItem_OnLoad(self)
            </OnLoad>
        </Scripts>
    </Button>

</Ui>
